{
  "name": "plataforma-jzf",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "nodemon --watch 'server/**/*.ts' --ignore 'server/dist/*' --exec 'ts-node' server/index.ts",
    "build": "npx prisma generate && npm run build:server && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "node server/dist/index.js",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "prisma": {
    "schema": "server/prisma/schema.prisma"
  },
  "dependencies": {
    "@google/genai": "^1.9.0",
    "@prisma/client": "^5.15.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lowdb": "^7.0.1",
    "marked": "^16.1.2",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/marked": "^6.0.0",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.2",
    "prisma": "^5.15.0",
    "tailwindcss": "^3.4.3",
    "ts-node": "^10.9.2",
    "vite": "^5.2.12"
  }
}