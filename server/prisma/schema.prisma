// server/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS

enum UserRole {
  AdminGeral
  AdminLimitado
  Cliente
}

enum TaxRegime {
  SimplesNacional
  LucroPresumido
  LucroReal
}

enum ClientStatus {
  Ativo
  Inativo
}

enum DocumentStatus {
  Pendente
  Recebido
  Revisado
  AguardandoAssinatura
  AguardandoAprovacao
  PendenteEtapa2
  Concluido
}

enum DocumentType {
  PDF
  Excel
  XML
  Outro
  Formulario
}

enum DocumentSource {
  cliente
  escritorio
}

enum InvoiceStatus {
  Pendente
  Pago
  Atrasado
}

enum TaskStatus {
  Pendente
  Concluida
}

enum OpportunityType {
  IncentivoFiscal
  EditalLicitacao
  Outro
}

enum ComplianceStatus {
  OK
  Atencao
  Pendencia
  Informativo
}

enum EmployeeStatus {
  Ativo
  Inativo
}

enum TimeSheetStatus {
  PendenteDeEnvio
  EnviadoParaAnalise
  Processado
  ErroNaAnalise
}


// MODELS

model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique
  password       String
  role           UserRole
  name           String
  email          String   @unique
  permissions    Json?
  clientIds      Json?
  activeClientId Int?
}

model Client {
  id              Int               @id @default(autoincrement())
  name            String
  company         String
  email           String
  phone           String
  status          ClientStatus?
  userId          Int               @unique
  taxRegime       TaxRegime?
  businessProfile Json
  documents       Document[]
  invoices        Invoice[]
  tasks           Task[]
  opportunities   Opportunity[]
  findings        ComplianceFinding[]
  employees       Employee[]
  timeSheets      TimeSheet[]
}

model Settings {
  id          Int     @id @default(1)
  pixKey      String?
  paymentLink String?
}

model TaskTemplateSet {
  id               String   @id @default(cuid())
  name             String
  taskDescriptions String[]
}

model DocumentTemplate {
  id         String @id @default(cuid())
  name       String
  fields     Json
  fileConfig Json?
  steps      Json?
}

model Document {
  id                  Int            @id @default(autoincrement())
  clientId            Int
  client              Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name                String
  description         String?
  type                DocumentType
  uploadDate          DateTime       @default(now())
  uploadedBy          String
  source              DocumentSource
  status              DocumentStatus
  requestText         String?
  file                Json?
  templateId          String?
  formData            Json?
  workflow            Json?
  signatures          Json[]
  requiredSignatories Json[]
  aiAnalysis          Json?
  auditLog            Json[]
}

model Invoice {
  id          String        @id @default(cuid())
  clientId    Int
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  description String
  amount      Float
  dueDate     DateTime
  status      InvoiceStatus
  boletoPdf   String?
  recurring   Json?
}

model AppNotification {
  id      Int      @id @default(autoincrement())
  userId  Int
  message String
  date    DateTime @default(now())
  read    Boolean  @default(false)
  link    String?
}

model Task {
  id           Int        @id @default(autoincrement())
  clientId     Int
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  description  String
  status       TaskStatus
  isRecurring  Boolean
  createdBy    String
  creationDate DateTime   @default(now())
}

model Opportunity {
  id                 String          @id @default(cuid())
  clientId           Int
  client             Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type               OpportunityType
  title              String
  description        String
  source             String
  dateFound          DateTime        @default(now())
  submissionDeadline DateTime?
}

model ComplianceFinding {
  id          String           @id @default(cuid())
  clientId    Int
  client      Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  status      ComplianceStatus
  summary     String
  sourceUrl   String
  dateChecked DateTime         @default(now())
}

model Employee {
  id         Int         @id @default(autoincrement())
  clientId   Int
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name       String
  role       String
  status     EmployeeStatus @default(Ativo)
  salary     Float
  timeSheets TimeSheet[]
}

model TimeSheet {
  id                    String          @id @default(cuid())
  clientId              Int
  client                Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employeeId            Int
  employee              Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month                 Int
  year                  Int
  status                TimeSheetStatus
  totalOvertimeHours50  Float           @default(0)
  totalOvertimeHours100 Float           @default(0)
  totalNightlyHours     Float           @default(0)
  totalLatenessMinutes  Int             @default(0)
  totalAbsencesDays     Int             @default(0)
  dsrValue              Float           @default(0)
  sourceFile            Json?
  aiAnalysisNotes       String?

  @@unique([clientId, employeeId, year, month])
}